# ============================================================
# PolicyLens RAG Engine — Environment Variables Template
# Copy to .env and fill in real values.
# NEVER commit .env — it is gitignored.
# ============================================================

# ── LlamaParse — PDF Parser (REQUIRED) ────────────────────────
# Sign up free at: https://cloud.llamaindex.ai
# Dashboard → API Keys → Create new key
LLAMA_CLOUD_API_KEY=llx-your-key-here

# ── Google Gemini — LLM (Fallback) ──────────────────────────
# Get a FREE API key at: https://aistudio.google.com/apikeys
# Model: gemini-3-flash-preview (free, fast, high quality)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3-flash-preview

# ── Groq — Fast Inference LLM (REQUIRED) ──────────────────────────
# Get an API key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
LLM_PROVIDER=groq
LLM_MODEL=openai/gpt-oss-20b

# ── (Legacy) Moonshot AI / Kimi — no longer required ────────
# These are kept for backward compatibility but are NOT needed.
# MOONSHOT_API_KEY=sk-your-moonshot-key-here
# KIMI_BASE_URL=https://api.moonshot.ai/v1
# KIMI_MODEL=moonshot-v1-8k

# ── Supabase — Database + Vector Store (REQUIRED) ──────────────
# Sign up free at: https://supabase.com
# Dashboard → Project Settings → API
# !! Use the service_role secret key — NOT the anon/public key !!
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VECTOR_TABLE_NAME=policy_chunks

# ── Jina AI — Embeddings (REQUIRED for default setup) ──────────
# Sign up free at: https://jina.ai → Get API Key (free tier = 1M tokens/mo)
JINA_API_KEY=jina_your-key-here
EMBEDDING_PROVIDER=jina
EMBEDDING_MODEL=jina-embeddings-v3
EMBEDDING_DIMENSION=768

# ── Reranker ─────────────────────────────────────────────────────
# cross_encoder = local, free, no key needed
# cohere = requires COHERE_API_KEY (free tier available)
RERANKER_PROVIDER=cross_encoder
COHERE_API_KEY=your-cohere-key-here

# ── Optional: OpenAI (only if EMBEDDING_PROVIDER=openai) ──────────
OPENAI_API_KEY=sk-your-key-here

# ── Debug ──────────────────────────────────────────────────────
DEBUG=false
